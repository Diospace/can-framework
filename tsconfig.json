{
  "compilerOptions": {
    "baseUrl": ".",
    "paths": {
      "@/*": ["src/*"],
      "@api/*": ["api/*"],
      "@build/*": ["build/*"]
    },
    "target": "ESNext",
    "module": "ESNext",
    "moduleResolution": "Bundler",
    "outDir": "dist",
    "declaration": true,
    "lib": ["ESNext", "DOM", "DOM.Iterable", "ES2015.Reflect"],
    "experimentalDecorators": true, // Essential for decorators
    "emitDecoratorMetadata": true,   // Essential for TypeORM to read decorator metadata
    "strictPropertyInitialization": false, // Often needed with TypeORM entities if you don't initialize all properties in the constructor
    "useDefineForClassFields": true,
    "esModuleInterop": true,
    "allowJs": true,
    "forceConsistentCasingInFileNames": true,
    "strict": true,
    "isolatedModules": true,
    "resolveJsonModule": true,
    "skipLibCheck": true,
    "types": ["node", "reflect-metadata"] 
  },

  "include": [
    "src/**/*",
    "api/**/*",
    "examples/**/*",
    "build/**/*"
  ],
  "exclude": [
    "node_modules",
    "dist"
  ]
}
